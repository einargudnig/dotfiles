{
  "workbench.sideBar.location": "right",
  "editor.fontLigatures": true,
  // "editor.fontLigatures": "'calt', 'liga', 'ss01', 'cv01' 2, 'cv31' 1",
  // "editor.fontFamily": "Fira code, monospace",
  // "editor.fontFamily": "'IBM Plex Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontFamily": "'Geist Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontWeight": "400",
  "editor.fontSize": 24,
  "editor.letterSpacing": 0.5,
  "editor.tabSize": 2,
  "workbench.iconTheme": "catppuccin-mocha",
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 5,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.stickyScroll.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.guides.highlightActiveIndentation": true,
  "terminal.external.osxExec": "iTerm.app",
  "terminal.integrated.env.osx": {},
  "terminal.integrated.fontFamily": "Geist Mono",
  "terminal.integrated.lineHeight": 1.3,
  "terminal.integrated.sendKeybindingsToShell": true,
  "terminal.explorerKind": "external",
  "diffEditor.ignoreTrimWhitespace": false,
  "workbench.editor.revealIfOpen": false,
  "zenMode.fullScreen": false,
  "zenMode.centerLayout": false,
  "editor.accessibilitySupport": "off",
  "workbench.colorCustomizations": {
    "editor.lineHighlightBackground": "#1073cf2d",
    "editor.lineHighlightBorder": "#9fced11f",
  },
  "editor.wordWrap": "off",
  "diffEditor.wordWrap": "off",
  "[markdown]": {
    "editor.wordWrap": "off",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off",
    },
  },
  "editor.guides.indentation": true,
  "prettier.requireConfig": true,
  "prettier.semi": false,
  "prettier.printWidth": 100,
  "editor.formatOnType": true,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.organizeImports": "always",
    "source.sortImports": "always",
    "source.fixAll.eslint": "explicit",
    "source.removeUnusedImports": "always",
  },
  "git.autofetch": true,
  "extensions.ignoreRecommendations": true,
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "editor.inlineSuggest.enabled": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "git.enableSmartCommit": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "yaml": false,
  },
  "search.useIgnoreFiles": false,
  "search.exclude": {
    "**/*.gitignore": true,
    "**/build": true,
    "**/node_modules": false,
    "**/node_modules/*/**": true,
  },
  "tailwindCSS.files.exclude": ["**/.git/**", "**/.hg/**", "**/.svn/**"],
  "workbench.settings.applyToAllProfiles": [
    "editor.formatOnSave",
    "editor.formatOnPaste",
  ],
  "liveshare.launcherClient": "visualStudioCode",
  "codestats.apikey": "SFMyNTY.WldsdVlYSm5kV1J1YVE9PSMjTVRReU1URT0.I3Sg8E4hHi4XtLtOMqFIIqazVf1XN4lIb-K2YhNE3CY",
  "codestats.username": "einargudni",
  "workbench.startupEditor": "none",
  "cSpell.userWords": ["organisations"],
  "prisma.showPrismaDataPlatformNotification": false,
  "github.copilot.editor.enableAutoCompletions": true,
  "[mdx]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports": "never",
      "source.removeUnusedImports": "never",
    },
  },
  "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.variableTypes.enabled": true,
  "better-comments.tags": [
    {
      "tag": "!",
      "color": "#FF2D00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "?",
      "color": "#3498DB",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "//",
      "color": "#474747",
      "strikethrough": true,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "todo",
      "color": "#FF8C00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "*",
      "color": "#98C379",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "#",
      "color": "#D64EB0",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "CRV",
      "color": "#8E44AD",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": true,
      "italic": false,
    },
  ],
  "workbench.editor.customLabels.patterns": {
    "**/{route.tsx}": "${dirname} ${filename}",
  },
  "workbench.productIconTheme": "icons-carbon",
  "github.copilot.selectedCompletionModel": "gpt-4o-copilot",
  "cursor.cpp.disabledLanguages": ["scminput", "yaml"],
  "git.openRepositoryInParentFolders": "always",
  "editor.fontVariations": false,
  "console-ninja.featureSet": "Community",

  "editor.lineNumbers": "relative",
  // Vim motions >>
  "vim.easymotion": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.highlightedyank.enable": true,
  "vim.incsearch": true,
  "vim.leader": "<space>",
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "k"],
      "after": ["<Esc>"],
    },
  ],

  "vim.normalModeKeyBindings": [
    {
      "before": [":"],
      "commands": ["workbench.action.showCommands"],
      "silent": true,
    },
    {
      "before": ["<leader>", ","],
      "command": ["workbench.action.showAllEditors"],
    },
  ],
  "cursor.cmdk.autoSelect": false,
  "playwright.reuseBrowser": false,
  "cursor.composer.textSizeScale": 1.3,
  "explorer.confirmDelete": false,
  "amp.url": "https://ampcode.com/",
  "cursor.composer.shouldAllowCustomModes": true,
  "update.releaseTrack": "prerelease",
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "totalTypeScript.hiddenTips": [
    "typing-function-parameters",
    "basic-types",
    "ts-object-type",
    "type-alias-declaration",
    "optional-object-property",
    "passing-generics-to-types",
    "union-type",
    "literal-type",
    "undefined-keyword",
    "null-keyword",
    "function-return-type",
    "variable-type-annotation",
    "record-utility-type",
    "any-type",
    "as-assertion",
    "non-null-expression",
    "as-const",
    "typeof",
    "returntype-utility-type",
    "tuple-type",
    "array-type",
  ],
  "vsicons.dontShowNewVersionMessage": true,
  "cursor.enable_git_worktrees_setting": true,
  "totalTypeScript.hideAllTips": true,
  "totalTypeScript.hideBasicTips": false,
  "workbench.colorTheme": "Catppuccin Mocha",
  "claudeCode.preferredLocation": "sidebar",
  "claudeCode.allowDangerouslySkipPermissions": true,
  "git.blame.editorDecoration.enabled": true,
  "gitlens.currentLine.enabled": false,
  "window.autoDetectColorScheme": false,
  // This is experimental!!
  // "typescript.experimental.useTsgo": true
}
